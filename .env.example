# First-boot seed only — after startup, edit tax rate via /admin/settings instead.
TAX_RATE=0.0825

# Required: secret used to sign staff sign-in tokens. Set this to a long random
# string in any real deployment — there is no safe default.
JWT_SECRET=change-me-to-a-long-random-string

# First-boot seed only — PIN for the auto-created default admin account.
# Change it via the admin panel immediately after first login.
BOOTSTRAP_ADMIN_PIN=1234
